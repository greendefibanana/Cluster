# ClusterFi Render Production Environment

NODE_ENV=production
PORT=10000
GATEWAY_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
ZERO_G_RPC_URL=https://evmrpc.0g.ai
ZERO_G_MAINNET_RPC_URL=https://evmrpc.0g.ai
ZERO_G_PROVIDER_MODE=real
TEST_MODE=FULL_TESTNET

# Security (Required for production startup)
# Create a secure random string (e.g. openssl rand -base64 32)
GATEWAY_AUTH_SECRET=
# Create a secure 32-byte hex string
INTELLIGENCE_ENCRYPTION_KEY=

# Optional Admin Token
ADMIN_API_TOKEN=

# Farcaster config
GATEWAY_CORS_ORIGINS= # e.g. https://your-vercel-project.vercel.app

# 0G Network Config
ZERO_G_PROVIDER=real
# Requires a funded 0G wallet for DA submission
ZERO_G_PRIVATE_KEY=

# Important Contract Addresses from deployments/mantleSepolia.json
AGENT_NFT_ADDRESS=0x3fBD3191f6a7a7537971C1809570E04A8DE14b44
ERC6551_REGISTRY_ADDRESS=0x52132b5e5544c44363185b755Bf20eF744C668bc
ERC6551_ACCOUNT_IMPLEMENTATION=0xd7a99F62bd695050818a66abEC90CeCebb67C9EC
MANTLE_TBA_ADDRESS=0xBe9cd56F9aD6e49eC5B7DA9307fF186Fa57fBd81

# Important 0G Contract Addresses
ZERO_G_IDENTITY_REGISTRY=0xE73C023D734D7AdC64E65D5Cc9C26Ef521dE0b0D
ZERO_G_REPUTATION_REGISTRY=0x740B80f98b68D069F52C40AfCE411686Db4d2eb3
ZERO_G_VALIDATION_REGISTRY=0xA2e443A435aFe4D8C1F01E71e41EaC2a25f31a97

# External Integrations
